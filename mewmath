	void rclamp2d(
		float& x_val, float& y_val, 
		float x_min, float x_max, 
		float y_min, float y_max,
		float x_step, float y_step
	) {
		if (x_val > x_max) {
			x_val = x_min;
			y_val += y_step;
		} else if (y_val > y_max) {
			y_val = y_min;
			x_val = x_min;
		} else {
			x_val += x_step;
		}
	}

