	template<typename T>
	struct Buffer {
		T* data;
		uint size;
		uint capacity;

		Buffer(uint cap) : size(0), capacity(cap) {
			data = new T[capacity];
		}
		~Buffer() {
			delete[] data;
		}
		void push_back(const T& value) {
			if (size < capacity) {
				data[size++] = value;
			}
		}
		void clear() {
			size = 0;
		}
