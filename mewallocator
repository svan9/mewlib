#ifndef MEW_ALLOCATOR_HPP
#define MEW_ALLOCATOR_HPP

#include "mewlib.h"
#include "mewtypes.h"

namespace mew {
	template<typename T, u64 alloc_size>
	class AllocatorBase {
	private:
		typedef AllocatorBase<T, alloc_size> self;
		u64 _M_size, _M_capacity;
		T* _M_data = nullptr;

		static T* _alloc(u64 count) {
			byte* ptr = new byte[count*sizeof(T)];
			memset(ptr, 0, count*sizeof(T));
			return (T*)ptr;
		}

		static void _dealloc(T* ptr) {
			ptr->~T();
			// if (std::is_arithmetic<T>::value || std::is_enum<T>::value) {
			// 	delete ptr;
			// } else {
			// 	delete[] ptr;
			// }
		}

		void _copy_all(T* dist, T* src) {
			for (u64 i = 0; i < _M_size; ++i) {
				T* to = dist+i;
				T* from = src+i;
				copy_to(to, *from);
			}
		}

	public:
		AllocatorBase() {}
		
		AllocatorBase(u64 count) : _M_capacity(count*alloc_size), _M_size(0) {
			_M_data = _alloc(count*alloc_size);
		}
		
		AllocatorBase(const self& ref): _M_capacity(ref._M_capacity), _M_size(ref._M_size) {
			_M_data = _alloc(_M_capacity);
			_copy_all(_M_data, ref._M_data);
		}
		
		AllocatorBase(self&& ref): _M_capacity(ref._M_capacity), _M_size(ref._M_size) {
			_M_data = _alloc(_M_capacity);
			_copy_all(_M_data, ref._M_data);
		}
		self& operator=(const self& ref) {
			_M_capacity = ref._M_capacity;
			_M_size = ref._M_size;
			_M_data = _alloc(_M_capacity);
			_copy_all(_M_data, ref._M_data);
			return *this;
		}
		
		self& operator=(self&& ref) {
			_M_capacity = ref._M_capacity;
			_M_size = ref._M_size;
			_M_data = _alloc(_M_capacity);
			_copy_all(_M_data, ref._M_data);
			return *this;
		}
		
		constexpr u64 AllocSize() const noexcept {
			return alloc_size;
		}

		~AllocatorBase() {
			if (_M_data) {
				_dealloc(_M_data);
			}
		}

		u64 size() const noexcept {
			return _M_size * sizeof(T);
		}

		u64 count() const noexcept {
			return _M_size;
		}

		T* alloc(s32 offset) {
			MewUserAssert(abs(offset) <= _M_size, "Index out of range");
			upsise();
			T* insert_begin = _M_data + offset;
			T* insert_end = insert_begin + 1;
			T* end = _M_size + _M_data;
			memmove(insert_end + 1, insert_begin, (end-insert_end)*sizeof(T));
			++_M_size;
			return insert_begin;
		}

		self concat(self other) {
			u64 new_size = other._M_size + _M_size;
			T* new_data = new T[new_size];
			memcpy(new_data, _M_data, size());
			memcpy(new_data+_M_size, other._M_data, other.size());
			_dealloc(_M_data);
			_M_data = new_data;
			_M_size = new_size;
			_M_capacity = new_size;
			return *this;
		}

		self concat_front(self other) {
			u64 new_size = other._M_size + _M_size;
			T* new_data = new T[new_size];
			memcpy(new_data, other._M_data, other.size());
			memcpy(new_data+other._M_size, _M_data, size());
			_dealloc(_M_data);
			_M_data = new_data;
			_M_size = new_size;
			_M_capacity = new_size;
			return *this;
		}

		void upsise() {
			if (_M_size+1 >= _M_capacity) {
				_M_capacity += alloc_size;
				T* new_data = _alloc(_M_capacity);
				_copy_all(new_data, _M_data);
				if (_M_data) {
					_dealloc(_M_data);
				}
				_M_data = new_data;
			}
		}

		void upsise(u64 _size) {
			if (_M_size+_size >= _M_capacity) {
				_M_capacity += alloc_size * _size;
				T* new_data = _alloc(_M_capacity);
				_copy_all(new_data, _M_data);
				if (_M_data) {
					_dealloc(_M_data);
				}
				_M_data = new_data;
			}
		}


		T* alloc() {
			upsise();
			return (T*)(_M_data) + _M_size++;
		}
		
		template<typename K>
		K* alloc() {
			upsise(sizeof(K));
			_M_size += sizeof(K);
			return (K*)(_M_data) + _M_size;
		}
		
		T* alloc_array(u64 _size) {
			upsise(_size);
			_M_size += _size;
			return (T*)(_M_data) + _M_size;
		}
		
		template<typename K>
		K* alloc_array(u64 _size) {
			upsise(sizeof(K) * _size);
			_M_size += sizeof(K) * _size;
			return (T*)(_M_data) + _M_size;
		}

		void copy(T* list, u64 size, u64 offset = 0) {
			if (_M_size + size + offset > _M_capacity) {
				_M_capacity += ((int)((_M_size + size + offset) / alloc_size)+1) * alloc_size;
				T* new_data = _alloc(_M_capacity);
				_copy_all(new_data, _M_data);
				if (_M_data) {
					_dealloc(_M_data);
				}
				_M_data = new_data;
			}
			memcpy((T*)(_M_data) + _M_size + offset, list, size * sizeof(T));
			_M_size += size;
		}

		void copy(self& other) {
			if (_M_size + other._M_size > _M_capacity) {
				_M_capacity += alloc_size;
				T* new_data = _alloc(_M_capacity);
				_copy_all(new_data, _M_data);
				if (_M_data) {
					_dealloc(_M_data);
				}
				_M_data = new_data;
			}
			memcpy((T*)(_M_data) + _M_size, other._M_data, other._M_size * sizeof(T));
			_M_size += other._M_size;
		}

		self copy() {
			self copy_alloc;
			copy_alloc._M_capacity = _M_capacity;
			copy_alloc._M_data = new T[_M_capacity];
			memcpy(copy_alloc._M_data, _M_data, _M_size * sizeof(T));
			copy_alloc._M_size = _M_size;
			return copy_alloc;
		}		

		void dealloc(T* ptr) {
			if (ptr >= (T*)(_M_data) && ptr < (T*)(_M_data) + _M_size) {
				--_M_size;
				memmove(ptr, ptr + 1, (_M_size - (ptr - (T*)(_M_data))) * sizeof(T));
			}
		}

		void clear() {
			_M_size = 0;
			memset(_M_data, 0, _M_capacity);
		}

		void fill(T value) {
			_M_size = _M_capacity;
			memset(_M_data, value, _M_capacity);
		}

		void clear(T value) {
			_M_size = 0;
			memset(_M_data, value, _M_capacity);
		}

		void shift() {
			if (_M_size > 0) {
				memmove(_M_data, (T*)(_M_data) + 1, (_M_size - 1) * sizeof(T));
				--_M_size;
			}
		}

		void reduceSize(u64 count) {
			if (count <= _M_size) {
				_M_size -= count;
			} else {
				_M_size = 0;
			}
		}

		void erase(u64 start, u64 size = 1) {
			MewUserAssert(size <= _M_size, "Index out of range");
			T* begin = (T*)(_M_data) + start;
			T* end = (T*)(begin) + size;
			u64 count = _M_size - size;
			memmove(begin, end, count * sizeof(T));
			_M_size -= size;
		}
		
		void eraseAfter(u64 start) {
			u64 size = count()-start; 
			MewUserAssert(size <= _M_size, "Index out of range");
			T* begin = (T*)(_M_data) + start;
			T* end = (T*)(begin) + size;
			u64 count = _M_size - size;
			memmove(begin, end, count * sizeof(T));
			_M_size -= size;
		}
		
		self shiftAfter(u64 start) {
			u64 _size = count()-start; 
			self nal(_size);
			T* array = nal.alloc_array(_size);
			T* begin = (T*)(_M_data) + start;
			memcpy(array, begin, sizeof(T)*_size);
			return nal;
		}

		void resize(u64 new_size) {
			if (new_size > _M_capacity) {
				_M_capacity = new_size * sizeof(T);
				T* new_data = new T[_M_capacity];
				memcpy(new_data, _M_data, _M_size * sizeof(T));
				if (_M_data) {
					_dealloc(_M_data);
				}
				_M_data = new_data;
			}
			_M_size = new_size;
		}

		void reserve(u64 size) {
			if (size > _M_capacity) {
				_M_capacity = size * sizeof(T);
				T* new_data = new T[_M_capacity];
				memcpy(new_data, _M_data, _M_size * sizeof(T));
				if (_M_data) {
					_dealloc(_M_data);
				}
				_M_data = new_data;
			}
		}

		T* begin() const noexcept {
			return (T*)(_M_data);
		}

		T* end() const noexcept {
			return (T*)(_M_data) + _M_size;
		}

		byte* rbegin() const noexcept {
			return (byte*)(_M_data);
		}

		byte* rend() const noexcept {
			return (byte*)(_M_data) + _M_size * sizeof(T);
		}
		
		void pop() {
			if (_M_size > 0) {
				--_M_size;
			}
		}
		
		void pop(u64 size) {
			if (_M_size*sizeof(T) > size) {
				_M_size -= size;
			} else {
				_M_size = 0;
			}
		}
	}; 

	template<typename T>
	using Allocator = AllocatorBase<T, 1>;

	template<typename T>
	using MidAllocator = AllocatorBase<T, 10>;
	
	template<typename T>
	using BigAllocator = AllocatorBase<T, 50>;

	template<typename T>
	using LargeAllocator = AllocatorBase<T, 100>;


};

#endif