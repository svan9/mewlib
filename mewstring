  template<typename T>
  void faspp(T& lhr, T val) {
    delete &lhr;
    lhr = val;
  }

  template<typename T>
  void fas(T& lhr, T val) {
    delete &lhr;
    lhr = val;
  }

  // free and swap
  template<typename T>
  void fas(T*& lhr, T* val) {
    delete lhr;
    lhr = val;
