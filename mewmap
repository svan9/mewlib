namespace Hash {
u64 get_hash(ID id) {
  return id;
}
u64 get_hash(const char* str) {
  u64 hash = 14695981039346656037ULL;
  while (*str) {
    hash ^= (uint8_t)*str++;
    hash *= 1099511628211ULL;
  }
  return hash;
}
u64 get_hash(const wchar_t* str) {
  u64 hash = 5381;
  wchar_t c;
  while ((c = *str++))
    hash = ((hash << 5) + hash) + c;  // hash * 33 + c
  return hash;
}

template <typename T>
u64 get_hash(const T& value) {
  return std::hash<T>{}(value);
}
}  // namespace Hash
