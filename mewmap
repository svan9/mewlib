template <typename Key, typename Value>
class map {
 private:
  struct Node {
    Key key;
    Value value;
    Node(Key& k, Value& v) : key(k), value(v) {}
  };

  std::vector<std::list<Node>> buckets;
  u64 size;
  static const u64 DEFAULT_CAPACITY = 16;
  static constexpr double LOAD_FACTOR = 0.75;

  u64 hash(Key key) const {
    return Hash::get_hash(key) % buckets.size();
  }

  void rehash() {
    std::vector<std::list<Node>> oldBuckets = buckets;
    buckets.clear();
    buckets.resize(oldBuckets.size() * 2);
    size = 0;
    for (auto& bucket : oldBuckets) {
      for (auto& node : bucket) {
        insert(node.key, node.value);
      }
    }
  }

 public:
  map() : buckets(DEFAULT_CAPACITY), size(0) {}

  map(std::initializer_list<std::pair<Key, Value>> init_list)
      : buckets(DEFAULT_CAPACITY), size(0) {
    for (const std::pair<Key, Value>& p : init_list) {
      insert((Key&)p.first, (Value&)p.second);
    }
  }

  void insert(Key& key, Value& value) {
    if (static_cast<double>(size) / buckets.size() >= LOAD_FACTOR) {
      rehash();
    }

    u64 index = hash(key);
    for (auto& node : buckets[index]) {
      if (node.key == key) {
        node.value = value;
        return;
      }
    }

    buckets[index].emplace_back(key, value);
    size++;
  }

  void insert(Key& key, Value&& value) {
    if (static_cast<double>(size) / buckets.size() >= LOAD_FACTOR) {
      rehash();
    }

    u64 index = hash(key);
    for (auto& node : buckets[index]) {
      if (node.key == key) {
        node.value = value;
        return;
      }
    }

    buckets[index].emplace_back(key, value);
    size++;
  }

  Value& at(Key key) {
    u64 index = hash(key);
    for (auto& node : buckets[index]) {
      if (node.key == key) {
        return node.value;
      }
    }
    throw std::out_of_range("Key not found");
  }

  bool contains(Key key) const {
    u64 index = hash(key);
    for (const auto& node : buckets[index]) {
      if (node.key == key) {
        return true;
      }
    }
    return false;
  }

  void erase(Key key) {
    u64 index = hash(key);
    auto& bucket = buckets[index];
    for (auto it = bucket.begin(); it != bucket.end(); ++it) {
      if (it->key == key) {
        bucket.erase(it);
        size--;
        return;
      }
    }
  }

  u64 getSize() const { return size; }
  bool isEmpty() const { return size == 0; }

  // for support
  class iterator {
    using bucket_iterator = typename std::list<Node>::iterator;
    using buckets_iterator = typename std::vector<std::list<Node>>::iterator;
    buckets_iterator buckets_it, buckets_end;
    bucket_iterator bucket_it;

    void advance_to_nonempty() {
      while (buckets_it != buckets_end && bucket_it == buckets_it->end()) {
        ++buckets_it;
        if (buckets_it != buckets_end)
          bucket_it = buckets_it->begin();
      }
    }

   public:
    iterator(buckets_iterator b_it, buckets_iterator b_end)
        : buckets_it(b_it), buckets_end(b_end), bucket_it(b_it != b_end ? b_it->begin() : bucket_iterator()) {
      advance_to_nonempty();
    }

    iterator& operator++() {
      ++bucket_it;
      advance_to_nonempty();
      return *this;
    }

    bool operator!=(const iterator& other) const {
      return buckets_it != other.buckets_it || (buckets_it != buckets_end && bucket_it != other.bucket_it);
    }

    Node& operator*() { return *bucket_it; }
    Node* operator->() { return &(*bucket_it); }
  };

  iterator begin() {
    return iterator(buckets.begin(), buckets.end());
  }

  iterator end() {
    return iterator(buckets.end(), buckets.end());
  }

  Node* first() {
    for (auto& bucket : buckets) {
      if (!bucket.empty()) {
        return &bucket.front();
      }
    }
    return nullptr;
  }

  Node* last() {
    for (auto b_it = buckets.rbegin(); b_it != buckets.rend(); ++b_it) {
      if (!b_it->empty()) {
        return &b_it->back();
      }
    }
    return nullptr;
  }
};

template <typename Value>
class hashmap {
 public:
  typedef u64 HashType;

 private:
  struct Node {
    HashType hash;
    Value value;
    Node(HashType h, const Value& v) : hash(h), value((Value)v) {}
    Node(HashType h, Value&& v) : hash(h), value((Value)std::move(v)) {}
  };

  std::vector<std::list<Node>> buckets;
  u64 size;
  static const u64 DEFAULT_CAPACITY = 16;
  static constexpr double LOAD_FACTOR = 0.75;

  u64 bucket_index(HashType hash) const {
    return hash % buckets.size();
  }

  void rehash() {
    std::vector<std::list<Node>> oldBuckets = buckets;
    buckets.clear();
    buckets.resize(oldBuckets.size() * 2);
    size = 0;
    for (auto& bucket : oldBuckets) {
      for (auto& node : bucket) {
        insert(node.hash, node.value);
      }
    }
  }

 public:
  hashmap() : buckets(DEFAULT_CAPACITY), size(0) {}

  Value& insert(HashType hash, const Value& value) {
    if (static_cast<double>(size) / buckets.size() >= LOAD_FACTOR) {
      rehash();
    }
    u64 index = bucket_index(hash);
    for (auto& node : buckets[index]) {
      if (node.hash == hash) {
        node.value = value;
        return node.value;
      }
    }
    buckets[index].emplace_back(hash, value);
    size++;
    return buckets[index].back().value;
  }

  Value& insert(HashType hash, Value&& value) {
    if (static_cast<double>(size) / buckets.size() >= LOAD_FACTOR) {
      rehash();
    }
    u64 index = bucket_index(hash);
    for (auto& node : buckets[index]) {
      if (node.hash == hash) {
        node.value = std::move(value);
        return node.value;
      }
    }
    buckets[index].emplace_back(hash, std::move(value));
    size++;
    return buckets[index].back().value;
  }
  template <typename T>
  Value& insert(T key, const Value& value) {
    HashType hash = Hash::get_hash(key);
    if (static_cast<double>(size) / buckets.size() >= LOAD_FACTOR) {
      rehash();
    }
    u64 index = bucket_index(hash);
    for (auto& node : buckets[index]) {
      if (node.hash == hash) {
        node.value = value;
        return node.value;
      }
    }
    buckets[index].emplace_back(hash, (Value)value);
    size++;
    return buckets[index].back().value;
  }

  template <typename T>
  Value& insert(T key, Value&& value) {
    HashType hash = Hash::get_hash(key);
    if (static_cast<double>(size) / buckets.size() >= LOAD_FACTOR) {
      rehash();
    }
    u64 index = bucket_index(hash);
    for (auto& node : buckets[index]) {
      if (node.hash == hash) {
        node.value = std::move(value);
        return node.value;
      }
    }
    buckets[index].emplace_back(hash, std::move(value));
    size++;
    return buckets[index].back().value;
  }

  Value& at(HashType hash) {
    u64 index = bucket_index(hash);
    for (auto& node : buckets[index]) {
      if (node.hash == hash) {
        return node.value;
      }
    }
    throw std::out_of_range("Hash not found");
  }

  template <typename T>
  Value& at(T key) {
    HashType hash = Hash::get_hash(key);
    u64 index = bucket_index(hash);
    for (auto& node : buckets[index]) {
      if (node.hash == hash) {
        return node.value;
      }
    }
    throw std::out_of_range("Hash not found");
  }

  bool contains(HashType hash) const {
    u64 index = bucket_index(hash);
    for (const auto& node : buckets[index]) {
      if (node.hash == hash) {
        return true;
      }
    }
    return false;
  }

  template <typename T>
  bool contains(T key) const {
    HashType hash = Hash::get_hash(key);
    u64 index = bucket_index(hash);
    for (const auto& node : buckets[index]) {
      if (node.hash == hash) {
        return true;
      }
    }
    return false;
  }

  void erase(HashType hash) {
    u64 index = bucket_index(hash);
    auto& bucket = buckets[index];
    for (auto it = bucket.begin(); it != bucket.end(); ++it) {
      if (it->hash == hash) {
        bucket.erase(it);
        size--;
        return;
      }
    }
  }

  u64 getSize() const { return size; }
  bool isEmpty() const { return size == 0; }

  class iterator {
    using bucket_iterator = typename std::list<Node>::iterator;
    using buckets_iterator = typename std::vector<std::list<Node>>::iterator;
    buckets_iterator buckets_it, buckets_end;
    bucket_iterator bucket_it;

    void advance_to_nonempty() {
      while (buckets_it != buckets_end && bucket_it == buckets_it->end()) {
        ++buckets_it;
        if (buckets_it != buckets_end)
          bucket_it = buckets_it->begin();
      }
    }

   public:
    iterator(buckets_iterator b_it, buckets_iterator b_end)
        : buckets_it(b_it), buckets_end(b_end), bucket_it(b_it != b_end ? b_it->begin() : bucket_iterator()) {
      advance_to_nonempty();
    }

    iterator& operator++() {
      ++bucket_it;
      advance_to_nonempty();
      return *this;
    }

    bool operator!=(const iterator& other) const {
      return buckets_it != other.buckets_it || (buckets_it != buckets_end && bucket_it != other.bucket_it);
    }

    Node& operator*() { return *bucket_it; }
    Node* operator->() { return &(*bucket_it); }
  };

  iterator begin() {
    return iterator(buckets.begin(), buckets.end());
  }

  iterator end() {
    return iterator(buckets.end(), buckets.end());
  }

  Node* first() {
    for (auto& bucket : buckets) {
      if (!bucket.empty()) {
        return &bucket.front();
      }
    }
    return nullptr;
  }

  Node* last() {
    for (auto b_it = buckets.rbegin(); b_it != buckets.rend(); ++b_it) {
      if (!b_it->empty()) {
        return &b_it->back();
      }
    }
    return nullptr;
  }
};

template <typename Key, typename Val>
class simple_map {
 public:
  struct pair {
    Key k;
    Val v;
  };

 private:
  mew::stack<pair> _M_elements;

 public:
  ////////////////////////////////////////////////////////////
  simple_map() {}

  ////////////////////////////////////////////////////////////
  bool has(Key& idx, u64* out_idx = nullptr) noexcept {
    for (int i = 0; i < _M_elements.size(); ++i) {
      pair* element = &_M_elements.at(i);
      if (0 == memcmp(&element->k, &idx, sizeof(Key))) {
        if (out_idx != nullptr) {
          *out_idx = i;
        }
        return true;
      }
    }
    *out_idx = -1;
    return false;
  }

  ////////////////////////////////////////////////////////////
  bool has(Key& idx, pair** out_pair = nullptr) noexcept {
    for (u64 i = 0; i < _M_elements.size(); ++i) {
      pair* element = &_M_elements.at(i);
      if (0 == memcmp(&element->k, &idx, sizeof(Key))) {
        if (out_pair != nullptr) {
          *out_pair = element;
        }
        return true;
      }
    }
    *out_pair = nullptr;
    return false;
  }

  ////////////////////////////////////////////////////////////
  Val& at(Key& idx) {
    pair* p = (pair*)malloc(sizeof(pair));
    MewAssert(has(idx, &p));
    return *p;
  }
  ////////////////////////////////////////////////////////////
  Val& at(const Key& idx) {
    pair* p = (pair*)malloc(sizeof(pair));
    MewAssert(has(idx, &p));
    return *p;
  }
  ////////////////////////////////////////////////////////////
  Val& at(Key&& idx) {
    pair* p = (pair*)malloc(sizeof(pair));
    MewAssert(has(idx, &p));
    return p->v;
  }

  ////////////////////////////////////////////////////////////
  u64 size() const noexcept {
    return _M_elements.size();
  }

  ////////////////////////////////////////////////////////////
  void erase(Key& idx) {
    u64 real_idx;
    MewAssert(has(idx, &real_idx));
    _M_elements.erase(real_idx);
  }

  ////////////////////////////////////////////////////////////
  bool empty() const noexcept {
    return _M_elements.empty();
  }

  ////////////////////////////////////////////////////////////
  void clear() {
    _M_elements.clear();
  }

  ////////////////////////////////////////////////////////////
  void insert(pair& p) {
    _M_elements.push(p);
  }

  ////////////////////////////////////////////////////////////
  void insert(pair&& p) {
    _M_elements.push(p);
  }
  ////////////////////////////////////////////////////////////
  void insert(const pair& p) {
    _M_elements.push(p);
  }
};
