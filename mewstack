////////////////////////////////////////////////////////////
template<typename T>
std::ostream& operator<<(std::ostream& os, const mew::stack<T> &as) {
  os << "{ ";
  for (size_t i = 0U; i < as.size(); ++i) {
    os << as[i] << ", ";
  }
  os << "}";
  return os;
}

////////////////////////////////////////////////////////////
template<typename T>
std::ostream& operator<<(std::ostream& os, const std::initializer_list<T> &is) {
  os << "{ ";
  for (size_t i = 0U; i < is.size(); ++i) {
    os << is.begin()[i] << ", ";
  }
  os << "}";
  return os;
}

